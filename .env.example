# ── Local LLM (fast drafts via Ollama) ───────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b-it-qf4_K_M   # or gemma4:e4b, llama3.1, etc.

# ── Quality-review LLM ────────────────────────────────────────────────────────
# Choose: deepseek  (cheaper, great quality)
#         openai    (GPT-4o / GPT-4o-mini)
REVIEW_PROVIDER=deepseek

# DeepSeek  → https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat          # or deepseek-reasoner for chain-of-thought

# OpenAI    → https://platform.openai.com/api-keys  (only needed if REVIEW_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini              # or gpt-4o for max quality

# ── Reddit OAuth (create app at reddit.com/prefs/apps) ────────────────────────
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=GhostDeskAgent/1.0 by /u/your_reddit_username

# ── Gmail SMTP (use App Password, not real password) ──────────────────────────
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Razorpay (analytics) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...

# ── Agent behavior ────────────────────────────────────────────────────────────
APPROVAL_REQUIRED=true   # set false to auto-post (risky)
CHAT_PORT=8765
LOG_LEVEL=INFO
